# Dark Factory Environment Configuration
# Copy to ~/.hermes/factory/env and customize for your project
#
# See: genie-pipeline SKILL.md → Dark Factory section

# Project settings (REQUIRED — replace placeholders)
FACTORY_PROJECT_DIR="{{PROJECT_PATH}}"
FACTORY_MAIN_BRANCH="main"
FACTORY_TICKET_PREFIX=""

# Local paths (defaults work for most setups)
FACTORY_LOG_DIR="$HOME/.hermes/factory/logs"
FACTORY_WORKTREE_DIR="$HOME/.hermes/factory/worktrees"

# Feature flags
FACTORY_USE_WORKTREES=true
FACTORY_AUTO_PERMISSIONS=false
FACTORY_AUTO_ATTACH=false

# Claude Code settings
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# Merge policy (do not change — enforced by factory-setup.sh)
FACTORY_MERGE_METHOD="squash"
FACTORY_REQUIRE_QUEUE=true
